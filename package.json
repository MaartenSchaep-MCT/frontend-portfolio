{
  "name": "frontend-portfolio-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.3",
    "@keystatic/core": "^0.5.50",
    "@keystatic/next": "^5.0.4",
    "@markdoc/markdoc": "^0.5.7",
    "lucide-react": "^1.3.0",
    "negotiator": "^1.0.0",
    "next": "16.2.2",
    "next-cloudinary": "^6.17.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "prettier": {
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "printWidth": 80,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": false,
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ],
    "importOrder": [
      "<BUILTIN_MODULES>",
      "",
      "^react$",
      "^next",
      "<THIRD_PARTY_MODULES>",
      "",
      "^@/(.*)$",
      "",
      "^[./]",
      "",
      "\\.css$"
    ],
    "importOrderParserPlugins": [
      "typescript",
      "jsx"
    ],
    "importOrderTypeScriptVersion": "5.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
